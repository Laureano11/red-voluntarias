---
import Layout from "../layouts/Layout.astro";
import Hero from "../components/Hero.astro";
import DogCard from "../components/DogCard.astro";
import { getCollection } from "astro:content";

const allDogs = await getCollection("dogs");
const availableDogs = allDogs.filter((d) => !d.data.adopted);
const adoptedDogs = allDogs.filter((d) => d.data.adopted);
---

<Layout title="Adoptá" description="Conocé a los perros disponibles para adopción. Cada uno busca un hogar lleno de amor.">
  <Hero
    title="Nuestros perros en adopción"
    subtitle="Cada uno tiene una historia y mucho amor para dar. ¿Te animás a darle un hogar?"
  />

  <section class="mx-auto max-w-7xl px-4 py-16 sm:px-6 lg:px-8">
    <!-- Filtros -->
    <div class="mb-10 flex flex-wrap items-center gap-3" id="filters">
      <span class="text-sm font-medium text-gray-500">Filtrar por tamaño:</span>
      <button data-filter="all" class="filter-btn active rounded-full bg-primary px-4 py-1.5 text-sm font-medium text-white">
        Todos
      </button>
      <button data-filter="Pequeño" class="filter-btn rounded-full bg-gray-200 px-4 py-1.5 text-sm font-medium text-gray-700 hover:bg-gray-300">
        Pequeño
      </button>
      <button data-filter="Mediano" class="filter-btn rounded-full bg-gray-200 px-4 py-1.5 text-sm font-medium text-gray-700 hover:bg-gray-300">
        Mediano
      </button>
      <button data-filter="Grande" class="filter-btn rounded-full bg-gray-200 px-4 py-1.5 text-sm font-medium text-gray-700 hover:bg-gray-300">
        Grande
      </button>
    </div>

    {availableDogs.length > 0 ? (
      <div class="grid gap-8 sm:grid-cols-2 lg:grid-cols-3" id="dogs-grid">
        {availableDogs.map((dog) => (
          <div data-size={dog.data.size}>
            <DogCard {...dog.data} />
          </div>
        ))}
      </div>
    ) : (
      <div class="rounded-2xl bg-white p-12 text-center shadow-sm">
        <p class="text-xl text-gray-500">No hay perros disponibles en este momento.</p>
        <p class="mt-2 text-gray-400">Volvé pronto, siempre hay nuevos rescatados.</p>
      </div>
    )}

    {adoptedDogs.length > 0 && (
      <div class="mt-16">
        <h2 class="text-2xl font-bold text-gray-900">Ya encontraron hogar 🎉</h2>
        <div class="mt-6 grid gap-8 sm:grid-cols-2 lg:grid-cols-3">
          {adoptedDogs.map((dog) => (
            <DogCard {...dog.data} />
          ))}
        </div>
      </div>
    )}
  </section>
</Layout>

<script>
  const buttons = document.querySelectorAll(".filter-btn");
  const cards = document.querySelectorAll("#dogs-grid > [data-size]");

  buttons.forEach((btn) => {
    btn.addEventListener("click", () => {
      const filter = btn.getAttribute("data-filter");

      buttons.forEach((b) => {
        b.classList.remove("bg-primary", "text-white", "active");
        b.classList.add("bg-gray-200", "text-gray-700");
      });
      btn.classList.remove("bg-gray-200", "text-gray-700");
      btn.classList.add("bg-primary", "text-white", "active");

      cards.forEach((card) => {
        const el = card as HTMLElement;
        if (filter === "all" || el.dataset.size === filter) {
          el.style.display = "";
        } else {
          el.style.display = "none";
        }
      });
    });
  });
</script>
