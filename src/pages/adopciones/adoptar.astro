---
import Layout from "../../layouts/Layout.astro";
import Hero from "../../components/Hero.astro";
import DogCard from "../../components/DogCard.astro";
import { getCollection } from "astro:content";

const allDogs = await getCollection("dogs");
const availableDogs = allDogs.filter((d) => !d.data.adopted);
const adoptedDogs = allDogs.filter((d) => d.data.adopted);
---

<Layout
  title="Adoptar"
  description="Catálogo de perros en adopción. Conocé su carácter, salud y tamaño. Completá el formulario para iniciar el proceso."
>
  <Hero
    title="Adoptar un perro"
    subtitle="Cada uno de ellos tiene una historia y espera una oportunidad. Para que sea un encuentro para toda la vida, te pedimos que leas atentamente el apartado Orientación para los adoptantes."
  />

  <section class="mx-auto max-w-7xl px-4 py-16 sm:px-6 lg:px-8">
    <p class="mx-auto mb-10 max-w-2xl text-center text-gray-600">
      Entender sus necesidades según su etapa vital es el primer paso para una adopción responsable y consciente.
    </p>

    {availableDogs.length > 0 ? (
      <div class="grid gap-8 sm:grid-cols-2 lg:grid-cols-3">
        {availableDogs.map((dog) => (
          <DogCard {...dog.data} />
        ))}
      </div>
    ) : (
      <div class="rounded-2xl bg-white p-12 text-center shadow-sm">
        <p class="text-xl text-gray-500">No hay perros disponibles en este momento.</p>
        <p class="mt-2 text-gray-400">Volvé pronto o escribinos por consultas.</p>
      </div>
    )}

    {adoptedDogs.length > 0 && (
      <div class="mt-16">
        <h2 class="text-2xl font-bold text-gray-900">Ya encontraron hogar</h2>
        <p class="mt-1 text-gray-500">¡Gracias a quienes adoptaron con responsabilidad!</p>
        <div class="mt-6 grid gap-8 sm:grid-cols-2 lg:grid-cols-3">
          {adoptedDogs.map((dog) => (
            <DogCard {...dog.data} />
          ))}
        </div>
      </div>
    )}
  </section>
</Layout>
