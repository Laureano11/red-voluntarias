    color: "from-slate-700 to-slate-500",
    icon: `<svg viewBox="0 0 24 24" fill="currentColor" class="h-7 w-7"><path d="M1.5 6.75A2.25 2.25 0 013.75 4.5h16.5A2.25 2.25 0 0122.5 6.75v10.5A2.25 2.25 0 0120.25 19.5H3.75A2.25 2.25 0 011.5 17.25V6.75zm2.49-.75a.75.75 0 00-.47 1.337l8.25 6.6a.75.75 0 00.94 0l8.25-6.6A.75.75 0 0020.01 6H3.99zm16.76 2.4l-5.99 4.79 5.99 4.79V8.4zm-1.7 9.6l-5.59-4.47-1.55 1.24a2.25 2.25 0 01-2.82 0l-1.55-1.24-5.59 4.47h17.1zm-17.1-.02l5.99-4.79-5.99-4.79v9.58z"/></svg>`,
  },
  {
    nombre: "WhatsApp",
    usuario: "11 2403-2191",
    href: "https://wa.me/541124032191",
    descripcion: "Escribinos para consultas sobre adopciones o cómo sumarte.",
    color: "from-green-500 to-green-400",
