const stats = [
  { numero: "150+", etiqueta: "Animales rescatados" },
  { numero: "120+", etiqueta: "Adopciones exitosas" },
  { numero: "40+", etiqueta: "Voluntarios activos" },
  { numero: "2020", etiqueta: "Año de fundación" },
