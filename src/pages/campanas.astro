---
import Layout from "../layouts/Layout.astro";
import Hero from "../components/Hero.astro";
import CampaignCard from "../components/CampaignCard.astro";
import { getCollection } from "astro:content";

const allCampaigns = await getCollection("campaigns");
const activeCampaigns = allCampaigns.filter((c) => c.data.active);
const pastCampaigns = allCampaigns.filter((c) => !c.data.active);
---

<Layout title="Campañas" description="Conocé nuestras campañas activas y cómo podés colaborar con tu donación.">
  <Hero
    title="Nuestras Campañas"
    subtitle="Cada donación, por pequeña que sea, marca una diferencia enorme en la vida de un animal."
  />

  <section class="mx-auto max-w-7xl px-4 py-16 sm:px-6 lg:px-8">
    {activeCampaigns.length > 0 ? (
      <>
        <h2 class="text-2xl font-bold text-gray-900">Campañas Activas</h2>
        <div class="mt-8 grid gap-8 md:grid-cols-2">
          {activeCampaigns.map((campaign) => (
            <CampaignCard {...campaign.data} />
          ))}
        </div>
      </>
    ) : (
      <div class="rounded-2xl bg-white p-12 text-center shadow-sm">
        <p class="text-xl text-gray-500">No hay campañas activas en este momento.</p>
        <p class="mt-2 text-gray-400">Seguinos en redes para enterarte de las próximas.</p>
      </div>
    )}

    {pastCampaigns.length > 0 && (
      <div class="mt-16">
        <h2 class="text-2xl font-bold text-gray-900">Campañas Anteriores</h2>
        <div class="mt-8 grid gap-8 md:grid-cols-2">
          {pastCampaigns.map((campaign) => (
            <CampaignCard {...campaign.data} />
          ))}
        </div>
      </div>
    )}
  </section>
</Layout>
