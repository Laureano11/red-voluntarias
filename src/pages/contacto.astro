---
import Layout from "../layouts/Layout.astro";
import Hero from "../components/Hero.astro";
---

<Layout title="Contacto" description="Ponete en contacto con Red Voluntarias para adopciones, voluntariado o donaciones.">
  <Hero
    title="Contactanos"
    subtitle="¿Querés adoptar, ser voluntario o simplemente tenés una consulta? Escribinos."
  />

  <section class="mx-auto max-w-4xl px-4 py-16 sm:px-6 lg:px-8">
    <div class="rounded-3xl bg-white p-8 text-center shadow-sm">
      <h2 class="text-2xl font-extrabold text-gray-900">Seguinos y escribinos</h2>
      <p class="mt-3 text-sm text-gray-600">
        Respondemos por nuestras redes. Elegí el canal que prefieras.
      </p>
      <div class="mt-8 grid gap-4 sm:grid-cols-2">
        <a
          href="https://instagram.com/red_de_voluntarias"
          target="_blank"
          rel="noopener noreferrer"
          class="flex items-center gap-4 rounded-2xl border border-gray-100 bg-surface px-5 py-4 text-left shadow-sm transition hover:-translate-y-0.5 hover:shadow-md"
        >
          <span class="flex h-12 w-12 items-center justify-center rounded-2xl bg-pink-500/10 text-pink-600" aria-hidden="true">
            <svg class="h-6 w-6" viewBox="0 0 24 24" fill="currentColor">
              <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z" />
            </svg>
          </span>
          <span>
            <span class="block text-sm font-semibold text-gray-900">Instagram</span>
            <span class="block text-xs text-gray-500">@red_de_voluntarias</span>
          </span>
        </a>
        <a
          href="https://www.tiktok.com/@red.de.voluntaria"
          target="_blank"
          rel="noopener noreferrer"
          class="flex items-center gap-4 rounded-2xl border border-gray-100 bg-surface px-5 py-4 text-left shadow-sm transition hover:-translate-y-0.5 hover:shadow-md"
        >
          <span class="flex h-12 w-12 items-center justify-center rounded-2xl bg-gray-900/10 text-gray-900" aria-hidden="true">
            <svg class="h-6 w-6" viewBox="0 0 24 24" fill="currentColor">
              <path d="M12.525.02c1.31-.02 2.61-.01 3.91-.02.08 1.53.63 3.09 1.75 4.17 1.12 1.11 2.7 1.62 4.24 1.79v4.03c-1.44-.05-2.89-.35-4.2-.97-.57-.26-1.1-.59-1.62-.93-.01 2.92.01 5.84-.02 8.75-.08 1.4-.54 2.79-1.35 3.94-1.31 1.92-3.58 3.17-5.91 3.21-1.43.08-2.86-.31-4.08-1.03-2.02-1.19-3.44-3.37-3.65-5.71-.02-.5-.03-1-.01-1.49.18-1.9 1.12-3.72 2.58-4.96 1.66-1.44 3.98-2.13 6.15-1.72.02 1.48-.04 2.96-.04 4.44-.99-.32-2.15-.23-3.02.37-.63.41-1.11 1.04-1.36 1.75-.21.51-.15 1.07-.14 1.61.24 1.64 1.82 3.02 3.5 2.87 1.12-.01 2.19-.66 2.77-1.61.19-.33.4-.67.41-1.06.1-1.79.06-3.57.07-5.36.01-4.03-.01-8.05.02-12.07z" />
            </svg>
          </span>
          <span>
            <span class="block text-sm font-semibold text-gray-900">TikTok</span>
            <span class="block text-xs text-gray-500">@red.de.voluntaria</span>
          </span>
        </a>
        <a
          href="https://wa.me/541124032191"
          target="_blank"
          rel="noopener noreferrer"
          class="flex items-center gap-4 rounded-2xl border border-gray-100 bg-surface px-5 py-4 text-left shadow-sm transition hover:-translate-y-0.5 hover:shadow-md"
        >
          <span class="flex h-12 w-12 items-center justify-center rounded-2xl bg-green-500/10 text-green-600" aria-hidden="true">
            <svg class="h-6 w-6" viewBox="0 0 24 24" fill="currentColor">
              <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z" />
            </svg>
          </span>
          <span>
            <span class="block text-sm font-semibold text-gray-900">WhatsApp</span>
            <span class="block text-xs text-gray-500">11 2403-2191</span>
          </span>
        </a>
        <a
          href="mailto:reddevoluntarias@gmail.com"
          class="flex items-center gap-4 rounded-2xl border border-gray-100 bg-surface px-5 py-4 text-left shadow-sm transition hover:-translate-y-0.5 hover:shadow-md"
        >
          <span class="flex h-12 w-12 items-center justify-center rounded-2xl bg-primary/10 text-primary-dark" aria-hidden="true">
            <svg class="h-6 w-6" viewBox="0 0 24 24" fill="currentColor">
              <path d="M1.5 6.75A2.25 2.25 0 013.75 4.5h16.5A2.25 2.25 0 0122.5 6.75v10.5A2.25 2.25 0 0120.25 19.5H3.75A2.25 2.25 0 011.5 17.25V6.75zm2.49-.75a.75.75 0 00-.47 1.337l8.25 6.6a.75.75 0 00.94 0l8.25-6.6A.75.75 0 0020.01 6H3.99zm16.76 2.4l-5.99 4.79 5.99 4.79V8.4zm-1.7 9.6l-5.59-4.47-1.55 1.24a2.25 2.25 0 01-2.82 0l-1.55-1.24-5.59 4.47h17.1zm-17.1-.02l5.99-4.79-5.99-4.79v9.58z" />
            </svg>
          </span>
          <span>
            <span class="block text-sm font-semibold text-gray-900">Email</span>
            <span class="block text-xs text-gray-500">reddevoluntarias@gmail.com</span>
          </span>
        </a>
      </div>
    </div>
  </section>

  <!-- Formularios -->
  <section class="mx-auto max-w-4xl px-4 pb-20 sm:px-6 lg:px-8">
    <div class="rounded-3xl bg-white p-8 shadow-sm">
      <h2 class="text-2xl font-extrabold text-gray-900 text-center">Formularios</h2>
      <p class="mt-3 text-sm text-gray-600 text-center">
        Completá el formulario que corresponda y te contactamos a la brevedad.
      </p>
      <div class="mt-8 grid gap-4 sm:grid-cols-3">
        <a
          href="https://forms.gle/5MYNETGAe3kJeLZ3A"
          target="_blank"
          rel="noopener noreferrer"
          class="flex flex-col items-center gap-3 rounded-2xl border border-gray-100 bg-surface px-5 py-6 text-center shadow-sm transition hover:-translate-y-0.5 hover:shadow-md"
        >
          <span class="flex h-12 w-12 items-center justify-center rounded-2xl bg-primary/10 text-primary-dark text-2xl">🐾</span>
          <span class="block text-sm font-bold text-gray-900">Adopciones</span>
          <span class="block text-xs text-primary-dark font-medium">Completar formulario →</span>
        </a>
        <a
          href="https://forms.gle/CXrCxpdSdPNqwKTL7"
          target="_blank"
          rel="noopener noreferrer"
          class="flex flex-col items-center gap-3 rounded-2xl border border-gray-100 bg-surface px-5 py-6 text-center shadow-sm transition hover:-translate-y-0.5 hover:shadow-md"
        >
          <span class="flex h-12 w-12 items-center justify-center rounded-2xl bg-primary/10 text-primary-dark text-2xl">🏡</span>
          <span class="block text-sm font-bold text-gray-900">Tránsitos</span>
          <span class="block text-xs text-primary-dark font-medium">Completar formulario →</span>
        </a>
        <a
          href="https://forms.gle/2a5zwZZh4ELAWa5m7"
          target="_blank"
          rel="noopener noreferrer"
          class="flex flex-col items-center gap-3 rounded-2xl border border-gray-100 bg-surface px-5 py-6 text-center shadow-sm transition hover:-translate-y-0.5 hover:shadow-md"
        >
          <span class="flex h-12 w-12 items-center justify-center rounded-2xl bg-primary/10 text-primary-dark text-2xl">🤝</span>
          <span class="block text-sm font-bold text-gray-900">Quiero ser voluntaria</span>
          <span class="block text-xs text-primary-dark font-medium">Completar formulario →</span>
        </a>
      </div>
    </div>
  </section>
</Layout>
