---
import Layout from "../layouts/Layout.astro";
import Hero from "../components/Hero.astro";
import DogCard from "../components/DogCard.astro";
import CampaignCard from "../components/CampaignCard.astro";
import { getCollection } from "astro:content";

const allDogs = await getCollection("dogs");
const featuredDogs = allDogs.filter((d) => d.data.featured && !d.data.adopted).slice(0, 3);

const allCampaigns = await getCollection("campaigns");
const activeCampaign = allCampaigns.find((c) => c.data.active);
---

<Layout title="Inicio" description="Red de voluntarios dedicados al rescate y adopción responsable de animales en situación de calle.">
  <Hero
    title="Dales una segunda oportunidad"
    subtitle="Somos una red de voluntarios que rescata, rehabilita y encuentra hogares amorosos para animales en situación de calle. Cada adopción cambia dos vidas."
    ctaText="Ver perros en adopción"
    ctaHref="/adopciones/adoptar"
  />

  <!-- Perros destacados -->
  <section class="mx-auto max-w-7xl px-4 py-16 sm:px-6 lg:px-8">
    <div class="text-center">
      <h2 class="text-3xl font-bold text-gray-900">Ellos te están esperando</h2>
      <p class="mx-auto mt-3 max-w-xl text-gray-600">
        Conocé a algunos de nuestros rescatados que buscan un hogar para siempre.
      </p>
    </div>

    <div class="mt-10 grid gap-8 sm:grid-cols-2 lg:grid-cols-3">
      {featuredDogs.map((dog) => (
        <DogCard {...dog.data} variant="compact" />
      ))}
    </div>

    <div class="mt-10 text-center">
      <a
        href="/adopciones/adoptar"
        class="inline-flex items-center gap-2 rounded-lg border-2 border-primary px-6 py-3 font-semibold text-primary transition-colors hover:bg-primary hover:text-white"
      >
        Ver todos los perros
        <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" />
        </svg>
      </a>
    </div>
  </section>

  <!-- Campaña activa -->
  {activeCampaign && (
    <section class="bg-surface-dark py-16">
      <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
        <div class="text-center">
          <h2 class="text-3xl font-bold text-gray-900">Campaña Activa</h2>
          <p class="mx-auto mt-3 max-w-xl text-gray-600">
            Tu aporte hace la diferencia. Ayudanos a alcanzar la meta.
          </p>
        </div>
        <div class="mx-auto mt-10 max-w-lg">
          <CampaignCard {...activeCampaign.data} />
        </div>
      </div>
    </section>
  )}

  <!-- CTA Final -->
  <section class="bg-gradient-to-r from-secondary to-amber-400 py-16 text-center">
    <div class="mx-auto max-w-3xl px-4">
      <h2 class="text-3xl font-bold text-gray-900">¿Querés ayudar?</h2>
      <p class="mt-4 text-lg text-gray-800">
        No solo adoptando podés cambiar vidas. Podés ser voluntario, hogar de tránsito o hacer una donación.
      </p>
      <a
        href="/contacto"
        class="mt-8 inline-flex rounded-full bg-gray-900 px-8 py-3 text-lg font-semibold text-white transition-colors hover:bg-gray-800"
      >
        Contactanos
      </a>
    </div>
  </section>
</Layout>
