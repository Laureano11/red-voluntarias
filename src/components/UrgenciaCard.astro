---
interface Props {
  titulo: string;
  descripcion: string;
  image: string;
  fecha?: string;
}

const { titulo, descripcion, image, fecha } = Astro.props;

let fechaLegible = fecha;
if (fecha && /^\d{4}-\d{2}-\d{2}$/.test(fecha)) {
  const [y, m, d] = fecha.split("-").map(Number);
  fechaLegible = new Date(y, m - 1, d).toLocaleDateString("es-AR", {
    day: "numeric",
    month: "long",
    year: "numeric",
  });
}
---

<article class="overflow-hidden rounded-2xl border-2 border-red-200 bg-white shadow-lg shadow-red-100 ring-1 ring-red-100">
  <div class="relative aspect-[16/10] overflow-hidden bg-gray-100 sm:aspect-[2/1]">
    <img src={image} alt={titulo} class="h-full w-full object-cover" loading="lazy" />
    <div class="absolute left-3 top-3 rounded-full bg-red-600 px-3 py-1 text-xs font-extrabold uppercase tracking-wide text-white shadow-md">
      Urgente
    </div>
  </div>
  <div class="border-t border-red-100 p-5 sm:p-6">
    {fechaLegible && (
      <time class="text-xs font-semibold uppercase tracking-wider text-red-600/90" datetime={fecha}>
        {fechaLegible}
      </time>
    )}
    <h2 class:list={[fechaLegible ? "mt-1" : "", "text-xl font-extrabold text-gray-900 sm:text-2xl"]}>
      {titulo}
    </h2>
    <p class="mt-3 whitespace-pre-line text-sm leading-relaxed text-gray-700">{descripcion}</p>
  </div>
</article>
