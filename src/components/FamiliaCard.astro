---
interface Props {
  name: string;
  image: string;
}

const { name, image } = Astro.props;
---

<article class="group overflow-hidden rounded-2xl bg-white shadow-md ring-1 ring-gray-100 transition-shadow hover:shadow-lg">
  <div class="relative aspect-square overflow-hidden bg-gray-100">
    <img
      src={image}
      alt={`${name}, ya en familia`}
      class="h-full w-full object-cover transition-transform duration-300 group-hover:scale-[1.03]"
      loading="lazy"
    />
  </div>
  <div class="border-t border-gray-100 px-4 py-4 text-center">
    <h2 class="text-lg font-bold text-gray-900">{name}</h2>
    <p class="mt-1 text-xs font-medium text-accent">En familia</p>
  </div>
</article>
