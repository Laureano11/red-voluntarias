---
interface Props {
  title: string;
  description: string;
  image: string;
  goal: number;
  raised: number;
  active: boolean;
}

const { title, description, image, goal, raised, active } = Astro.props;
const progress = Math.min(Math.round((raised / goal) * 100), 100);
---

<article class="overflow-hidden rounded-2xl bg-white shadow-md transition-all hover:shadow-xl">
  <div class="relative aspect-video overflow-hidden">
    <img
      src={image}
      alt={title}
      class="h-full w-full object-cover"
      loading="lazy"
    />
    {!active && (
      <div class="absolute inset-0 flex items-center justify-center bg-black/50">
        <span class="rounded-full bg-gray-600 px-4 py-2 text-sm font-bold text-white">
          Finalizada
        </span>
      </div>
    )}
  </div>

  <div class="p-6">
    <h3 class="text-xl font-bold text-gray-900">{title}</h3>
    <p class="mt-2 line-clamp-3 text-sm leading-relaxed text-gray-600">{description}</p>

    <div class="mt-5">
      <div class="flex items-end justify-between text-sm">
        <span class="font-semibold text-accent">${raised.toLocaleString()} recaudados</span>
        <span class="text-gray-500">Meta: ${goal.toLocaleString()}</span>
      </div>
      <div class="mt-2 h-3 overflow-hidden rounded-full bg-gray-200">
        <div
          class="h-full rounded-full bg-gradient-to-r from-accent to-emerald-400 transition-all"
          style={`width: ${progress}%`}
        ></div>
      </div>
      <p class="mt-1 text-right text-xs text-gray-400">{progress}%</p>
    </div>

    {active && (
      <a
        href="/contacto"
        class="mt-4 inline-flex w-full items-center justify-center rounded-lg bg-secondary px-4 py-2.5 text-sm font-semibold text-gray-900 transition-colors hover:bg-secondary-dark"
      >
        Donar Ahora
      </a>
    )}
  </div>
</article>
