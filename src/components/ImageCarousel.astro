---
import type { ImagenProyecto } from "../data/proyectos";

interface Props {
  imagenes: ImagenProyecto[];
  proyectoId: string;
}

const { imagenes, proyectoId } = Astro.props;
const modalId = `carousel-${proyectoId}`;
const preview = imagenes.slice(0, 3);
const hasMore = imagenes.length > 3;
---

<!-- Preview grid -->
<div class="mt-6">
  <div
    class:list={[
      "grid gap-2",
      preview.length === 1 && "grid-cols-1",
      preview.length === 2 && "grid-cols-2",
      preview.length >= 3 && "grid-cols-2",
    ]}
  >
    {preview.map((img, i) => (
      <button
        type="button"
        class:list={[
          "group relative overflow-hidden rounded-2xl bg-gray-100 ring-1 ring-gray-100 focus:outline-none focus-visible:ring-2 focus-visible:ring-primary",
          preview.length >= 3 && i === 0 && "col-span-2",
        ]}
        data-carousel-open={modalId}
        data-carousel-index={i}
        aria-label={`Ver galería: ${img.alt}`}
      >
        <img
          src={img.src}
          alt={img.alt}
          loading="lazy"
          class:list={[
            "w-full object-cover transition duration-300 group-hover:scale-[1.03]",
            preview.length >= 3 && i === 0 ? "aspect-[16/7]" : "aspect-square sm:aspect-[4/3]",
          ]}
        />
        {/* Overlay on last preview if there are more */}
        {hasMore && i === preview.length - 1 && (
          <div class="absolute inset-0 flex flex-col items-center justify-center bg-black/55 text-white">
            <span class="text-3xl font-extrabold">+{imagenes.length - 3}</span>
            <span class="mt-1 text-sm font-medium">Ver todas</span>
          </div>
        )}
      </button>
    ))}
  </div>
</div>

<!-- Modal carrusel -->
<div
  id={modalId}
  role="dialog"
  aria-modal="true"
  aria-label="Galería de fotos"
  class="fixed inset-0 z-[100] hidden items-center justify-center bg-black/85 p-4 backdrop-blur-sm"
>
  <!-- Cerrar al hacer clic fuera -->
  <div class="absolute inset-0" data-carousel-close={modalId}></div>

  <div class="relative z-10 flex h-full max-h-[90dvh] w-full max-w-4xl flex-col">
    <!-- Barra superior -->
    <div class="flex shrink-0 items-center justify-between pb-3">
      <span id={`${modalId}-counter`} class="text-sm font-semibold text-white/70"></span>
      <button
        type="button"
        data-carousel-close={modalId}
        aria-label="Cerrar galería"
        class="flex h-9 w-9 items-center justify-center rounded-full bg-white/10 text-white hover:bg-white/25 transition"
      >
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" class="h-5 w-5"><path d="M18 6 6 18M6 6l12 12"/></svg>
      </button>
    </div>

    <!-- Imagen principal -->
    <div class="relative flex min-h-0 flex-1 items-center justify-center">
      <button
        type="button"
        data-carousel-prev={modalId}
        aria-label="Foto anterior"
        class="absolute left-0 z-10 flex h-10 w-10 items-center justify-center rounded-full bg-white/10 text-white hover:bg-white/25 transition sm:-left-12"
      >
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" class="h-5 w-5"><path d="m15 18-6-6 6-6"/></svg>
      </button>

      <img
        id={`${modalId}-img`}
        src=""
        alt=""
        class="max-h-full max-w-full rounded-xl object-contain shadow-2xl"
      />

      <button
        type="button"
        data-carousel-next={modalId}
        aria-label="Foto siguiente"
        class="absolute right-0 z-10 flex h-10 w-10 items-center justify-center rounded-full bg-white/10 text-white hover:bg-white/25 transition sm:-right-12"
      >
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" class="h-5 w-5"><path d="m9 18 6-6-6-6"/></svg>
      </button>
    </div>

    <!-- Thumbnails -->
    <div class="mt-3 flex shrink-0 gap-2 overflow-x-auto pb-1">
      {imagenes.map((img, i) => (
        <button
          type="button"
          data-carousel-thumb={modalId}
          data-carousel-index={i}
          aria-label={img.alt}
          class="h-14 w-14 shrink-0 overflow-hidden rounded-lg ring-2 ring-transparent transition hover:ring-white/60 focus:outline-none"
        >
          <img src={img.src} alt={img.alt} loading="lazy" class="h-full w-full object-cover" />
        </button>
      ))}
    </div>
  </div>
</div>

<script define:vars={{ modalId, imagenes }}>
  (function () {
    const modal = document.getElementById(modalId);
    if (!modal) return;

    const imgEl = document.getElementById(`${modalId}-img`);
    const counterEl = document.getElementById(`${modalId}-counter`);
    const thumbs = modal.querySelectorAll(`[data-carousel-thumb="${modalId}"]`);
    let current = 0;

    function show(index) {
      current = (index + imagenes.length) % imagenes.length;
      imgEl.src = imagenes[current].src;
      imgEl.alt = imagenes[current].alt;
      counterEl.textContent = `${current + 1} / ${imagenes.length}`;
      thumbs.forEach((t, i) => {
        t.classList.toggle("ring-white", i === current);
        t.classList.toggle("ring-transparent", i !== current);
      });
    }

    function open(index) {
      show(index);
      modal.classList.remove("hidden");
      modal.classList.add("flex");
      document.body.style.overflow = "hidden";
    }

    function close() {
      modal.classList.add("hidden");
      modal.classList.remove("flex");
      document.body.style.overflow = "";
    }

    // Abrir desde previews
    document.querySelectorAll(`[data-carousel-open="${modalId}"]`).forEach((btn) => {
      btn.addEventListener("click", () => open(Number(btn.dataset.carouselIndex)));
    });

    // Cerrar
    modal.querySelectorAll(`[data-carousel-close="${modalId}"]`).forEach((el) => {
      el.addEventListener("click", close);
    });

    // Prev / Next
    modal.querySelector(`[data-carousel-prev="${modalId}"]`)?.addEventListener("click", () => show(current - 1));
    modal.querySelector(`[data-carousel-next="${modalId}"]`)?.addEventListener("click", () => show(current + 1));

    // Thumbnails
    thumbs.forEach((btn) => {
      btn.addEventListener("click", () => show(Number(btn.dataset.carouselIndex)));
    });

    // Teclado
    document.addEventListener("keydown", (e) => {
      if (modal.classList.contains("hidden")) return;
      if (e.key === "ArrowLeft") show(current - 1);
      if (e.key === "ArrowRight") show(current + 1);
      if (e.key === "Escape") close();
    });
  })();
</script>
