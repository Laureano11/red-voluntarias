---
import type { Proyecto } from "../data/proyectos";
import ImageCarousel from "./ImageCarousel.astro";

interface Props {
  proyecto: Proyecto;
  index: number;
}

const { proyecto, index } = Astro.props;
const hasGallery = proyecto.imagenes.length > 0;
const isEven = index % 2 === 0;
---

<article
  id={proyecto.id}
  class="scroll-mt-24 rounded-3xl border border-gray-100 bg-white p-6 shadow-sm sm:p-8 lg:p-10"
>
  <header class="flex flex-col gap-3 sm:flex-row sm:items-start sm:justify-between">
    <div>
      {proyecto.periodo && (
        <span class="inline-block rounded-full bg-primary/10 px-3 py-1 text-xs font-semibold uppercase tracking-wide text-primary">
          {proyecto.periodo}
        </span>
      )}
      <h2 class="mt-3 text-2xl font-extrabold text-gray-900 sm:text-3xl">
        {proyecto.titulo}
      </h2>
      {proyecto.subtitulo && (
        <p class="mt-2 text-base font-medium text-gray-500">{proyecto.subtitulo}</p>
      )}
    </div>
    <span
      class="hidden h-14 w-14 shrink-0 items-center justify-center rounded-2xl bg-surface text-2xl font-bold text-primary/40 sm:flex"
      aria-hidden="true"
    >
      {String(index + 1).padStart(2, "0")}
    </span>
  </header>

  <div
    class:list={[
      "mt-8 gap-10",
      hasGallery ? "grid lg:grid-cols-2 lg:gap-12" : "max-w-3xl space-y-4",
    ]}
  >
    <!-- Texto -->
    <div class:list={["space-y-4", hasGallery && !isEven && "lg:order-2"]}>
      {proyecto.descripcion.map((parrafo) => (
        <p class="text-base leading-relaxed text-gray-600">{parrafo}</p>
      ))}
    </div>

    <!-- Galería con carrusel -->
    {hasGallery && (
      <div class:list={[hasGallery && !isEven && "lg:order-1"]}>
        <ImageCarousel imagenes={proyecto.imagenes} proyectoId={proyecto.id} />
      </div>
    )}
  </div>

  <!-- Videos -->
  {proyecto.videos.length > 0 && (
    <div class="mt-10 border-t border-gray-100 pt-10">
      <h3 class="mb-6 flex items-center gap-2 text-sm font-bold uppercase tracking-wider text-gray-400">
        <span class="flex h-8 w-8 items-center justify-center rounded-lg bg-secondary/15 text-lg" aria-hidden="true">▶</span>
        Videos
      </h3>
      <div class="grid gap-8 sm:grid-cols-2">
        {proyecto.videos.map((video) => (
          <div class="flex flex-col gap-3">
            <p class="font-semibold text-gray-900">{video.titulo}</p>
            <div class="aspect-video overflow-hidden rounded-2xl bg-gray-900 shadow-md ring-1 ring-gray-200">
              <iframe
                class="h-full w-full"
                src={`https://www.youtube-nocookie.com/embed/${video.youtubeId}`}
                title={video.titulo}
                loading="lazy"
                allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
                allowfullscreen
              />
            </div>
          </div>
        ))}
      </div>
    </div>
  )}
</article>
