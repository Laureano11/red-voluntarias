---
interface Props {
  nombre: string;
  descripcion: string;
  precio: string;
  image: string;
}

const { nombre, descripcion, precio, image } = Astro.props;
---

<article class="flex h-full flex-col overflow-hidden rounded-2xl bg-white shadow-md ring-1 ring-gray-100 transition-shadow hover:shadow-lg">
  <div class="relative aspect-[4/3] overflow-hidden bg-gray-100">
    <img
      src={image}
      alt={nombre}
      class="h-full w-full object-cover"
      loading="lazy"
    />
  </div>
  <div class="flex flex-1 flex-col p-5">
    <p class="text-lg font-extrabold text-gray-900">{nombre}</p>
    <p class="mt-2 flex-1 text-sm leading-relaxed text-gray-600">{descripcion}</p>
    <p class="mt-4 text-xl font-bold text-primary">{precio}</p>
  </div>
</article>
